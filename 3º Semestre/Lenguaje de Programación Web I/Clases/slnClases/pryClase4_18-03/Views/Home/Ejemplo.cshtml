
@{
    ViewData["Title"] = "Ejemplo";
}

<h1>Datos:</h1>
<br />
<form asp-controller="Home" asp-action="validardatos" method="post">
    <label>Usuario</label>
    <input type="text" name="usuario" id="txtUsuario" />
    <br />
    <label>Contraseña</label>
    <input type="password" name="contraseña" id="txtContraseña" />
    <br />
    <input type="submit" value="Aceptar" />
</form>

<h1 style="color:@ViewBag.color; display: flex; justify-content: center; align-items: center;">
    @ViewBag.respuesta
</h1>

<img src="@ViewBag.imagen" />